{
  "$schema": "./schema.json",
  "schemaVersion": 1,
  "id": "logical-composition.expectation.any",
  "category": "logical-composition",
  "syntax": "any { <expectation>... }",
  "normative": {
    "operator": "any",
    "evaluatesAllChildren": true,
    "passCondition": "anyChildPassed",
    "emptyBlockPolicy": "semanticError",
    "emptyBlockDiagnosticCode": "semantic.expectation.empty_block"
  },
  "conformanceCases": [
    {
      "description": "any passes when at least one child passes",
      "assertionSource": "any {\n      exit 0\n      exit 1\n    }",
      "assertion": {
        "subject": "logical",
        "operator": "any",
        "children": [
          { "subject": "exit", "operator": "equals", "expected": 0 },
          { "subject": "exit", "operator": "equals", "expected": 1 }
        ]
      },
      "checkpoint": {
        "exitCode": 0,
        "stdout": { "data": "", "encoding": "base64", "text": "" },
        "stderr": { "data": "", "encoding": "base64", "text": "" }
      },
      "expectedResult": "pass"
    },
    {
      "description": "any fails when every child fails",
      "assertionSource": "any {\n      exit 1\n      exit 2\n    }",
      "assertion": {
        "subject": "logical",
        "operator": "any",
        "children": [
          { "subject": "exit", "operator": "equals", "expected": 1 },
          { "subject": "exit", "operator": "equals", "expected": 2 }
        ]
      },
      "checkpoint": {
        "exitCode": 0,
        "stdout": { "data": "", "encoding": "base64", "text": "" },
        "stderr": { "data": "", "encoding": "base64", "text": "" }
      },
      "expectedResult": "fail"
    },
    {
      "description": "invalid: an empty any block is a semantic error, not evaluated as vacuously false",
      "assertionSource": "any {\n    }",
      "expectedResult": "parseError",
      "expectedDiagnosticCode": "semantic.expectation.empty_block"
    }
  ]
}

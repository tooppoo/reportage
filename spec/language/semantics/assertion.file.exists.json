{
  "$schema": "./schema.json",
  "schemaVersion": 1,
  "id": "assertion.file.exists",
  "category": "assertion",
  "syntax": "file <\"path\"> exists",
  "normative": {
    "checkpointField": "file",
    "operator": "exists",
    "expectedValueType": "none",
    "matchSemantics": {
      "comparison": "existence"
    }
  },
  "conformanceCases": [
    {
      "description": "file exists passes when the path is a regular file",
      "assertionSource": "file <\"actual.txt\"> exists",
      "assertion": { "subject": "file", "path": "actual.txt", "operator": "exists" },
      "checkpoint": {
        "exitCode": 0,
        "stdout": { "data": "", "encoding": "base64", "text": "" },
        "stderr": { "data": "", "encoding": "base64", "text": "" },
        "workspace": {
          "files": [
            { "path": "actual.txt", "contents": { "data": "aGVsbG8=", "encoding": "base64", "text": "hello" } }
          ]
        }
      },
      "expectedResult": "pass"
    },
    {
      "description": "file exists fails when the path does not exist",
      "assertionSource": "file <\"missing.txt\"> exists",
      "assertion": { "subject": "file", "path": "missing.txt", "operator": "exists" },
      "checkpoint": {
        "exitCode": 0,
        "stdout": { "data": "", "encoding": "base64", "text": "" },
        "stderr": { "data": "", "encoding": "base64", "text": "" }
      },
      "expectedResult": "fail",
      "expectedDiagnosticCode": "assertion.file.exists_missing"
    },
    {
      "description": "file exists fails when the path is a directory, not a regular file",
      "assertionSource": "file <\"adir\"> exists",
      "assertion": { "subject": "file", "path": "adir", "operator": "exists" },
      "checkpoint": {
        "exitCode": 0,
        "stdout": { "data": "", "encoding": "base64", "text": "" },
        "stderr": { "data": "", "encoding": "base64", "text": "" },
        "workspace": {
          "dirs": ["adir"]
        }
      },
      "expectedResult": "fail",
      "expectedDiagnosticCode": "assertion.file.exists_not_a_file"
    }
  ]
}

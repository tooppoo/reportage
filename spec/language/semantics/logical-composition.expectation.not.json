{
  "$schema": "./schema.json",
  "schemaVersion": 1,
  "id": "logical-composition.expectation.not",
  "category": "logical-composition",
  "syntax": "not { <expectation>... }",
  "normative": {
    "operator": "not",
    "evaluatesAllChildren": true,
    "passCondition": "notAllChildrenPassed",
    "emptyBlockPolicy": "semanticError",
    "emptyBlockDiagnosticCode": "semantic.expectation.empty_block"
  },
  "conformanceCases": [
    {
      "description": "not passes when its single child fails",
      "assertionSource": "not { exit 1 }",
      "assertion": {
        "subject": "logical",
        "operator": "not",
        "children": [
          { "subject": "exit", "operator": "equals", "expected": 1 }
        ]
      },
      "checkpoint": {
        "exitCode": 0,
        "stdout": { "data": "", "encoding": "base64", "text": "" },
        "stderr": { "data": "", "encoding": "base64", "text": "" }
      },
      "expectedResult": "pass"
    },
    {
      "description": "not fails when its single child passes",
      "assertionSource": "not { exit 0 }",
      "assertion": {
        "subject": "logical",
        "operator": "not",
        "children": [
          { "subject": "exit", "operator": "equals", "expected": 0 }
        ]
      },
      "checkpoint": {
        "exitCode": 0,
        "stdout": { "data": "", "encoding": "base64", "text": "" },
        "stderr": { "data": "", "encoding": "base64", "text": "" }
      },
      "expectedResult": "fail"
    },
    {
      "description": "not with multiple children negates the group as a whole (implicit all), not each child individually: one child passes and the other fails, so the group fails and not passes",
      "assertionSource": "not {\n      exit 0\n      stdout contains \"nope\"\n    }",
      "assertion": {
        "subject": "logical",
        "operator": "not",
        "children": [
          { "subject": "exit", "operator": "equals", "expected": 0 },
          { "subject": "stdout", "operator": "contains", "expected": "nope" }
        ]
      },
      "checkpoint": {
        "exitCode": 0,
        "stdout": { "data": "aGVsbG8K", "encoding": "base64", "text": "hello\n" },
        "stderr": { "data": "", "encoding": "base64", "text": "" }
      },
      "expectedResult": "pass"
    },
    {
      "description": "invalid: an empty not block is a semantic error, not evaluated as vacuously true or false",
      "assertionSource": "not {\n    }",
      "expectedResult": "parseError",
      "expectedDiagnosticCode": "semantic.expectation.empty_block"
    }
  ]
}

{
  "name": "reportage-vscode",
  "displayName": "Reportage",
  "description": "Syntax highlighting and code snippets for reportage files.",
  "version": "0.0.1",
  "publisher": "philomagi",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "url": "https://github.com/tooppoo/reportage"
  },
  "homepage": "https://github.com/tooppoo/reportage",
  "author": {
    "name": "philomagi",
    "url": "https://philomagi.dev"
  },
  "icon": "./assets/reportage-ext.png",
  "scripts": {
    "generate:readme": "node scripts/generate-readme.mjs",
    "check:readme": "node scripts/generate-readme.mjs --check",
    "package": "node scripts/generate-readme.mjs && vsce package --baseContentUrl https://github.com/tooppoo/reportage/blob/HEAD/editors/vscode --baseImagesUrl https://github.com/tooppoo/reportage/raw/HEAD/editors/vscode --out ./reportage-vscode.vsix"
  },
  "packageManager": "pnpm@11.9.0",
  "categories": [
    "Programming Languages"
  ],
  "files": [
    "package.json",
    "README.md",
    "LICENSE",
    "language-configuration.json",
    "syntaxes/reportage.tmLanguage.json",
    "snippets/reportage.json",
    "assets/reportage-ext.png",
    "assets/reportage-icon.png"
  ],
  "contributes": {
    "languages": [
      {
        "id": "reportage",
        "aliases": [
          "Reportage",
          "reportage"
        ],
        "extensions": [
          ".repor"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/reportage-icon.png",
          "dark": "./assets/reportage-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "reportage",
        "scopeName": "source.reportage",
        "path": "./syntaxes/reportage.tmLanguage.json",
        "embeddedLanguages": {
          "source.shell.embedded.reportage": "shellscript"
        }
      }
    ],
    "snippets": [
      {
        "language": "reportage",
        "path": "./snippets/reportage.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "3.9.2"
  }
}
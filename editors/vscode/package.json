{
  "name": "reportage-vscode",
  "displayName": "Reportage",
  "description": "Syntax highlighting support for reportage files.",
  "version": "0.0.0",
  "publisher": "philomagi",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "url": "https://github.com/tooppoo/reportage/actions"
  },
  "homepage": "https://github.com/tooppoo/reportage/actions",
  "author": {
    "name": "philomagi",
    "url": "https://philomagi.dev"
  },
  "icon": "icons/reportage-extension-icon.png",
  "scripts": {
    "package": "vsce package --out ./reportage-vscode.vsix"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "reportage",
        "aliases": [
          "Reportage",
          "reportage"
        ],
        "extensions": [
          ".repor"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/reportage-icon-light.svg",
          "dark": "./icons/reportage-icon-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "reportage",
        "scopeName": "source.reportage",
        "path": "./syntaxes/reportage.tmLanguage.json",
        "embeddedLanguages": {
          "source.shell.embedded.reportage": "shellscript"
        }
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "3.9.2"
  }
}
{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Reportage",
  "scopeName": "source.reportage",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#action-line"
    },
    {
      "include": "#assertion-block"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.reportage",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.reportage",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.reportage",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "action-line": {
      "patterns": [
        {
          "name": "meta.action.line.reportage",
          "begin": "^(\\s*)(\\$)(?=\\s|$)",
          "beginCaptures": {
            "2": {
              "name": "keyword.operator.action.reportage"
            }
          },
          "contentName": "source.shell.embedded.reportage",
          "end": "$",
          "patterns": [
            {
              "name": "entity.name.function.command.reportage",
              "match": "\\G\\s*([^\\s#]+)",
              "captures": {
                "1": {
                  "name": "entity.name.function.command.reportage"
                }
              }
            },
            {
              "name": "variable.parameter.option.reportage",
              "match": "(?<=\\s)--?[A-Za-z0-9][A-Za-z0-9_-]*"
            },
            {
              "include": "source.shell"
            }
          ]
        }
      ]
    },
    "assertion-block": {
      "patterns": [
        {
          "name": "meta.assertion.block.reportage",
          "begin": "^(\\s*)(assert)\\b\\s*(\\{)?",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.assert.reportage"
            },
            "3": {
              "name": "punctuation.section.block.begin.reportage"
            }
          },
          "end": "^(\\s*)(\\})",
          "endCaptures": {
            "2": {
              "name": "punctuation.section.block.end.reportage"
            }
          },
          "patterns": [
            {
              "match": "^(\\s*)(exit|stdout|stderr)\\b",
              "captures": {
                "2": {
                  "name": "entity.name.function.expectation.reportage"
                }
              }
            },
            {
              "name": "keyword.operator.expectation.reportage",
              "match": "\\b(contains|equals|matches|exists)\\b"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.reportage",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.reportage",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.reportage",
          "match": "\\}"
        }
      ]
    }
  }
}
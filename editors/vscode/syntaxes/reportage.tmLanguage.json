{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Reportage",
  "scopeName": "source.reportage",
  "patterns": [
    {
      "include": "#heredoc-block"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#case-block"
    },
    {
      "include": "#action-line"
    },
    {
      "include": "#assertion-block"
    },
    {
      "include": "#workspace-path"
    },
    {
      "include": "#fixture-reference"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.reportage",
          "match": "(?:^|(?<=[ \\t]))#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.reportage",
          "begin": "\"",
          "end": "\"|$",
          "patterns": [
            {
              "name": "constant.character.escape.reportage",
              "match": "\\\\(?:\\\\|\\\"|n|t)"
            }
          ]
        }
      ]
    },
    "workspace-path": {
      "patterns": [
        {
          "name": "meta.workspace-path.reportage",
          "match": "(<)(\"(?:[^\"\\\\]|\\\\.)*\")(>)",
          "captures": {
            "1": {
              "name": "punctuation.definition.workspace-path.begin.reportage"
            },
            "2": {
              "name": "variable.other.constant.workspace-path.reportage",
              "patterns": [
                {
                  "name": "constant.character.escape.reportage",
                  "match": "\\\\(?:\\\\|\\\"|n|t)"
                }
              ]
            },
            "3": {
              "name": "punctuation.definition.workspace-path.end.reportage"
            }
          }
        }
      ]
    },
    "fixture-reference": {
      "patterns": [
        {
          "name": "meta.fixture-reference.reportage",
          "match": "(@)(\"(?:[^\"\\\\]|\\\\.)*\")",
          "captures": {
            "1": {
              "name": "punctuation.definition.fixture-reference.reportage"
            },
            "2": {
              "name": "support.function.fixture-reference.reportage",
              "patterns": [
                {
                  "name": "constant.character.escape.reportage",
                  "match": "\\\\(?:\\\\|\\\"|n|t)"
                }
              ]
            }
          }
        }
      ]
    },
    "case-block": {
      "patterns": [
        {
          "match": "^(\\s*)(case)\\b",
          "captures": {
            "2": {
              "name": "keyword.control.case.reportage"
            }
          }
        }
      ]
    },
    "heredoc-block": {
      "patterns": [
        {
          "name": "meta.heredoc.block.reportage",
          "begin": "^(\\s*)(write|file)\\b(.*?)(`{3,})\\s*$",
          "beginCaptures": {
            "2": {
              "patterns": [
                {
                  "include": "#keywords"
                }
              ]
            },
            "3": {
              "patterns": [
                {
                  "include": "#workspace-path"
                },
                {
                  "include": "#fixture-reference"
                },
                {
                  "include": "#strings"
                },
                {
                  "include": "#keywords"
                }
              ]
            },
            "4": {
              "name": "punctuation.definition.raw.begin.reportage"
            }
          },
          "end": "^\\s*(\\4`*)\\s*$",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.raw.end.reportage"
            }
          },
          "contentName": "string.unquoted.raw.reportage"
        }
      ]
    },
    "action-line": {
      "patterns": [
        {
          "name": "meta.action.line.reportage",
          "begin": "^(\\s*)(\\$)(?=\\s|$)",
          "beginCaptures": {
            "2": {
              "name": "keyword.operator.action.reportage"
            }
          },
          "contentName": "source.shell.embedded.reportage",
          "end": "(?<!\\\\)$",
          "patterns": [
            {
              "name": "entity.name.function.command.reportage",
              "match": "\\G\\s*([^\\s#]+)",
              "captures": {
                "1": {
                  "name": "entity.name.function.command.reportage"
                }
              }
            },
            {
              "name": "variable.parameter.option.reportage",
              "match": "(?<=\\s)--?[A-Za-z0-9][A-Za-z0-9_-]*"
            },
            {
              "include": "source.shell"
            }
          ]
        }
      ]
    },
    "assertion-block": {
      "patterns": [
        {
          "name": "meta.assertion.block.reportage",
          "begin": "^(\\s*)(assert)\\b\\s*(\\{)?",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.assert.reportage"
            },
            "3": {
              "name": "punctuation.section.block.begin.reportage"
            }
          },
          "end": "(\\s*)(\\})",
          "endCaptures": {
            "2": {
              "name": "punctuation.section.block.end.reportage"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#heredoc-block"
            },
            {
              "include": "#logical-block"
            },
            {
              "include": "#keywords"
            },
            {
              "include": "#workspace-path"
            },
            {
              "include": "#fixture-reference"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "logical-block": {
      "patterns": [
        {
          "name": "meta.logical.block.reportage",
          "begin": "(\\s*)(not|all|any)\\b\\s*(\\{)?",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.logical.reportage"
            },
            "3": {
              "name": "punctuation.section.block.begin.reportage"
            }
          },
          "end": "(\\s*)(\\})",
          "endCaptures": {
            "2": {
              "name": "punctuation.section.block.end.reportage"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#heredoc-block"
            },
            {
              "include": "#logical-block"
            },
            {
              "include": "#keywords"
            },
            {
              "include": "#workspace-path"
            },
            {
              "include": "#fixture-reference"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#punctuation"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.reportage",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.write.reportage",
          "match": "\\bwrite\\b"
        },
        {
          "name": "entity.name.function.expectation.reportage",
          "match": "\\b(exit|stdout|stderr|file|dir)\\b"
        },
        {
          "name": "keyword.operator.expectation.reportage",
          "match": "\\b(contains|contents_equals|text_equals|exists|empty)\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.reportage",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.reportage",
          "match": "\\}"
        }
      ]
    }
  }
}

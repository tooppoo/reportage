{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Reportage",
  "scopeName": "source.reportage",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#action-line"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#expectation-words"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.reportage",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.reportage",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.reportage",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "action-line": {
      "patterns": [
        {
          "name": "meta.action.line.reportage",
          "begin": "^(\\s*)(\\$)(?=\\s|$)",
          "beginCaptures": {
            "2": {
              "name": "keyword.operator.action.reportage"
            }
          },
          "contentName": "source.shell.embedded.reportage",
          "end": "$",
          "patterns": [
            {
              "name": "entity.name.function.command.reportage",
              "match": "\\G\\s*([^\\s#]+)",
              "captures": {
                "1": {
                  "name": "entity.name.function.command.reportage"
                }
              }
            },
            {
              "name": "variable.parameter.option.reportage",
              "match": "(?<=\\s)--?[A-Za-z0-9][A-Za-z0-9_-]*"
            },
            {
              "include": "source.shell"
            }
          ]
        }
      ]
    }
  }
}

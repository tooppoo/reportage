{
  "name": "reportage-dev",
  "image": "mcr.microsoft.com/devcontainers/base:2.1.10-trixie",
  "workspaceFolder": "/workspaces/reportage",
  "remoteUser": "vscode",
  "runArgs": [
    "--init"
  ],
  "postCreateCommand": "sh scripts/setup-dev.sh",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/rust:1.5.0": {
      "version": "1.96.0"
    },
    "ghcr.io/tooppoo/catalog-devcontainer-features/git-kura:0": {
      "version": "0.0.6"
    },
    "ghcr.io/devcontainers/features/node:2": {
      "version": "24.18.0",
      "pnpmVersion": "11.9.0"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "EditorConfig.EditorConfig",
        "rust-lang.rust-analyzer",
        "kdl-org.kdl",
        "skellock.just"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.eol": "\n"
      }
    }
  }
}

# install the javascript shim example's dependencies. must run before reportage exercises the
# `sample` command, since the shim's `npx c8`/`npx tsx` invocations resolve packages from this
# project's own node_modules; without a prior install, npx falls back to fetching them from the
# registry on first use and prints a "will be installed" warning to stderr, which the example's
# `stderr empty` assertions do not expect.
js-install:
  cd javascript && npm ci

# its own `npm ci` duplicates `js-install`'s when both run in the same CI job, but `npm ci` is
# idempotent and this recipe is also meant to be runnable standalone (without `js-install` having
# run first), so it keeps its own install rather than assuming a prior step already did it.
js-coverage-100:
  cd javascript && npm ci && npm run check

# build the coverage-instrumented binary the go shim execs, and clear coverage output left over
# from a prior local run: both the go and javascript shims add new coverage files on every
# invocation without clearing old ones, so a stale file from an earlier run could let
# `go-coverage-100` / `js-coverage-100` report 100% even after a real regression, if this
# recipe (which always runs immediately before the example suite, in both `just check` and CI)
# did not clear them first.
go-build:
  rm -rf go/coverage go/.reportage javascript/coverage
  cd go && go build -cover -o bin/sample ./src

go-coverage-100:
  #!/usr/bin/env sh
  set -eu
  cd go
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT
  go tool covdata textfmt -i=coverage/reportage/go -o="$tmp"
  report=$(go tool cover -func="$tmp")
  echo "$report"
  total=$(echo "$report" | awk '/^total:/ { gsub("%", "", $NF); print $NF }')
  awk -v total="$total" 'BEGIN { exit (total >= 100.0) ? 0 : 1 }' || {
    echo "ERROR: go coverage (${total}%) does not meet threshold (100%)"
    exit 1
  }

# warm the rust shim's instrumented build cache, and clear coverage output left over from a prior local run for the same stale-coverage reason `go-build` documents.
# the shim rebuilds on every invocation anyway (cargo makes that incremental), so this recipe exists to clear stale coverage and to keep the first suite invocation from paying the full cold-build cost.
rust-build:
  rm -rf rust/coverage rust/.reportage
  cd rust && RUSTFLAGS='-C instrument-coverage' cargo build --quiet --bin sample --target-dir .reportage/shims/rust/target

# llvm-profdata/llvm-cov come from rustup's llvm-tools component (pinned in rust-toolchain.toml), which installs them into the toolchain sysroot rather than onto PATH.
# the percentage is taken from `llvm-cov export` JSON via jq instead of parsing the human-readable report's columns, whose layout is not stable across llvm-cov versions.
rust-coverage-100:
  #!/usr/bin/env sh
  set -eu
  cd rust
  bin='.reportage/shims/rust/target/debug/sample'
  tools_dir="$(dirname "$(rustc --print target-libdir)")/bin"
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT
  "$tools_dir/llvm-profdata" merge -sparse coverage/reportage/rust/*.profraw -o "$tmp"
  "$tools_dir/llvm-cov" report "$bin" -instr-profile="$tmp" src/main.rs
  total=$("$tools_dir/llvm-cov" export --summary-only "$bin" -instr-profile="$tmp" src/main.rs | jq '.data[0].totals.lines.percent')
  awk -v total="$total" 'BEGIN { exit (total >= 100.0) ? 0 : 1 }' || {
    echo "ERROR: rust line coverage (${total}%) does not meet threshold (100%)"
    exit 1
  }

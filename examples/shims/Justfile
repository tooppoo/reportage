
js-coverage-100:
  cd javascript && npm ci && npm run check

# build the coverage-instrumented binary the go shim execs, and clear coverage output left over
# from a prior local run: both the go and javascript shims add new coverage files on every
# invocation without clearing old ones, so a stale file from an earlier run could let
# `go-coverage-100` / `js-coverage-100` report 100% even after a real regression, if this
# recipe (which always runs immediately before the example suite, in both `just check` and CI)
# did not clear them first.
go-build:
  rm -rf go/coverage go/.reportage javascript/coverage
  cd go && go build -cover -o bin/sample ./src

go-coverage-100:
  #!/usr/bin/env sh
  set -eu
  cd go
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT
  go tool covdata textfmt -i=coverage/reportage/go -o="$tmp"
  report=$(go tool cover -func="$tmp")
  echo "$report"
  total=$(echo "$report" | awk '/^total:/ { gsub("%", "", $NF); print $NF }')
  awk -v total="$total" 'BEGIN { exit (total >= 100.0) ? 0 : 1 }' || {
    echo "ERROR: go coverage (${total}%) does not meet threshold (100%)"
    exit 1
  }
